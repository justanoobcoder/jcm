#!/usr/bin/env python3
import os
import sys
import sqlite3
import argparse
import subprocess
import time
import hashlib
import json

CACHE_DIR = os.path.join(os.getenv("XDG_CACHE_HOME", os.path.expanduser("~/.cache")), "jcm")
DATA_DIR = os.path.join(os.getenv("XDG_DATA_HOME", os.path.expanduser("~/.local/share")), "jcm")
IMAGE_DIR = os.path.join(CACHE_DIR, "images")
DB_PATH = os.path.join(DATA_DIR, "history.db")
LOG_FILE = os.path.join(CACHE_DIR, "daemon.log")
JSON_CONFIG_PATH = os.path.expanduser("~/.config/jcm/settings.json")

def log(msg):
    with open(LOG_FILE, "a") as f:
        f.write(f"[{time.ctime()}] {msg}\n")

def init_db():
    os.makedirs(IMAGE_DIR, exist_ok=True)
    os.makedirs(DATA_DIR, exist_ok=True)
    log("Initializing DB...")
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS history
                 (id INTEGER PRIMARY KEY AUTOINCREMENT, 
                  content TEXT, 
                  type TEXT, 
                  timestamp INTEGER, 
                  pinned INTEGER DEFAULT 0)''')
    c.execute('''CREATE TABLE IF NOT EXISTS settings
                 (key TEXT PRIMARY KEY, value TEXT)''')
    conn.commit()
    conn.close()

def get_setting(key, default):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT value FROM settings WHERE key=?", (key,))
    row = c.fetchone()
    conn.close()
    return row[0] if row else default

def set_setting(key, value):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO settings(key, value) VALUES (?, ?)", (key, value))
    conn.commit()
    conn.close()

def get_json_setting(key, default):
    if not os.path.exists(JSON_CONFIG_PATH):
        return default
    try:
        with open(JSON_CONFIG_PATH, "r") as f:
            data = json.load(f)
            return data.get(key, default)
    except Exception as e:
        log(f"Error reading JSON config: {e}")
        return default

def set_json_setting(key, value):
    data = {}
    if os.path.exists(JSON_CONFIG_PATH):
        try:
            with open(JSON_CONFIG_PATH, "r") as f:
                data = json.load(f)
        except Exception:
            pass
            
    data[key] = value
    os.makedirs(os.path.dirname(JSON_CONFIG_PATH), exist_ok=True)
    try:
        with open(JSON_CONFIG_PATH, "w") as f:
            json.dump(data, f, indent=4)
    except Exception as e:
        log(f"Error writing JSON config: {e}")

def watch():
    init_db()
    log("Starting watch mode...")
    log("Exec: wl-paste --watch jcm-daemon store")
    os.execvp("wl-paste", ["wl-paste", "--watch", "jcm-daemon", "store"])

def store():
    log("Store triggered")
    # Consume stdin fully to prevent pipe buffer deadlocks.
    # wl-paste --watch writes the selection to our stdin. Large payloads (images)
    # fill the 64KB OS pipe buffer. If we don't read it, wl-paste hangs endlessly,
    # deadlocking the Wayland clipboard and causing our own wl-paste calls to timeout.
    try:
        sys.stdin.buffer.read()
    except Exception as e:
        log(f"Error consuming stdin: {e}")

    if get_setting('is_paused', 'false') == 'true':
        log("Recording paused, ignoring")
        return

    try:
        types_out = subprocess.check_output(['wl-paste', '--list-types'], stderr=subprocess.DEVNULL).decode().splitlines()
        log(f"Types: {types_out}")
    except subprocess.CalledProcessError as e:
        log(f"Error listing types: {e}")
        return

    image_types = [t for t in types_out if t.startswith('image/')]
    text_types = [t for t in types_out if t.startswith('text/') or t in ('UTF8_STRING', 'STRING')]
    
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()

    captured = False

    if image_types:
        # Prioritize image capture if any image types exist
        best_type = 'image/png' if 'image/png' in image_types else image_types[0]
        try:
            log(f"Attempting to capture image type: {best_type}")
            result = subprocess.run(
                ['wl-paste', '--type', best_type],
                capture_output=True, timeout=3
            )
            if result.returncode == 0 and result.stdout:
                data = result.stdout
                h = hashlib.sha256(data).hexdigest()
                filepath = os.path.join(IMAGE_DIR, f"{h}.png")
                c.execute("SELECT id FROM history WHERE content=?", (filepath,))
                existing = c.fetchone()
                if existing:
                    log(f"Duplicate image, updating timestamp: {existing[0]}")
                    c.execute("UPDATE history SET timestamp=? WHERE id=?", (int(time.time()), existing[0]))
                else:
                    log(f"New image captured: {filepath}")
                    with open(filepath, 'wb') as f:
                        f.write(data)
                    c.execute("INSERT INTO history(content, type, timestamp, pinned) VALUES (?, ?, ?, 0)",
                              (filepath, 'image', int(time.time())))
                conn.commit()
                captured = True
            else:
                stderr_msg = result.stderr.decode('utf-8', errors='replace') if result.stderr else "No stderr"
                log(f"Image capture failed with return code {result.returncode}. Stderr: {stderr_msg}")
        except subprocess.TimeoutExpired:
            log("Image capture timed out, skipping")
        except Exception as e:
            log(f"Error capturing image: {e}")

    if not captured and text_types:
        try:
            log("Attempting to capture text")
            result = subprocess.run(
                ['wl-paste', '--no-newline'],
                capture_output=True, timeout=3
            )
            if result.returncode != 0:
                log(f"wl-paste text failed: {result.stderr.decode()}")
                conn.close()
                return
            data = result.stdout.decode('utf-8', errors='replace')
            if not data.strip():
                log("Captured text is empty, ignoring")
                conn.close()
                return
            c.execute("SELECT id FROM history WHERE content=? AND type='text'", (data,))
            existing = c.fetchone()
            if existing:
                log(f"Duplicate text, updating timestamp: {existing[0]}")
                c.execute("UPDATE history SET timestamp=? WHERE id=?", (int(time.time()), existing[0]))
            else:
                log(f"New text captured: {data[:50]!r}")
                c.execute("INSERT INTO history(content, type, timestamp, pinned) VALUES (?, ?, ?, 0)",
                          (data, 'text', int(time.time())))
            conn.commit()
        except subprocess.TimeoutExpired:
            log("Text capture timed out")
        except Exception as e:
            log(f"Error capturing text: {e}")

    conn.close()


def db_list(search="", type_filter=""):
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    query = "SELECT * FROM history WHERE 1=1"
    params = []
    if type_filter and type_filter != "all":
        query += " AND type=?"
        params.append(type_filter)
    if search:
        query += " AND type='text' AND content LIKE ?"
        params.append(f"%{search}%")
    query += " ORDER BY pinned DESC, timestamp DESC"
    c.execute(query, params)
    rows = c.fetchall()
    
    result = []
    for r in rows:
        result.append(dict(r))
    
    print(json.dumps(result))
    conn.close()

def delete(item_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT type, content FROM history WHERE id=?", (item_id,))
    row = c.fetchone()
    if row:
        if row[0] == 'image':
            try: os.remove(row[1])
            except: pass
        c.execute("DELETE FROM history WHERE id=?", (item_id,))
        conn.commit()
    conn.close()

def clear():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT content FROM history WHERE type='image' AND pinned=0")
    for row in c.fetchall():
        try: os.remove(row[0])
        except: pass
    c.execute("DELETE FROM history WHERE pinned=0")
    conn.commit()
    conn.close()

def set_pin(item_id, pinned):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("UPDATE history SET pinned=? WHERE id=?", (1 if pinned else 0, item_id))
    conn.commit()
    conn.close()

def edit_item(item_id, content):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("UPDATE history SET content=? WHERE id=? AND type='text'", (content, item_id))
    conn.commit()
    conn.close()

def get_clip(item_id):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute("SELECT content, type FROM history WHERE id=?", (item_id,))
    row = c.fetchone()
    conn.close()
    
    if not row:
        return
        
    content, ctype = row
    
    if ctype == 'text':
        subprocess.run(['wl-copy', '--type', 'text/plain'], input=content.encode('utf-8'))
    elif ctype == 'image':
        with open(content, 'rb') as f:
            data = f.read()
        subprocess.run(['wl-copy', '--type', 'image/png'], input=data)
        
    if get_setting('paste_right_away', 'false') == 'true':
        # Fork to background the paste operation so this process can return 
        # immediately, allowing Quickshell to quit and refocus the previous window.
        try:
            if os.fork() == 0:
                # In child process
                time.sleep(0.3) # Increased delay to ensure JCM window is gone
                subprocess.run(['wtype', '-M', 'ctrl', '-k', 'v', '-m', 'ctrl'])
                os._exit(0)
        except AttributeError:
            # Fallback for systems without os.fork
            subprocess.Popen([sys.executable, "-c", 
                f"import subprocess, time; time.sleep(0.3); subprocess.run(['wtype', '-M', 'ctrl', '-k', 'v', '-m', 'ctrl'])"])

def open_url(url):
    log(f"Opening URL: {url}")
    subprocess.Popen(['xdg-open', url])

def open_image(filepath):
    viewer = get_json_setting("image_viewer", "xdg-open")
    log(f"Opening image: {filepath} with {viewer}")
    # Split the command into arguments (e.g., "imv -f" -> ["imv", "-f"])
    import shlex
    cmd = shlex.split(viewer)
    cmd.append(filepath)
    try:
        # Fully detach the viewer process so Quickshell doesn't kill it when this short-lived daemon script returns
        subprocess.Popen(cmd, start_new_session=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, stdin=subprocess.DEVNULL)
    except Exception as e:
        log(f"Error opening image with {viewer}: {e}")

def main():
    parser = argparse.ArgumentParser(description="JCM Backend Daemon")
    subparsers = parser.add_subparsers(dest="command")
    
    subparsers.add_parser("watch")
    subparsers.add_parser("store")
    
    list_parser = subparsers.add_parser("list")
    list_parser.add_argument("--search", default="", help="Search query")
    list_parser.add_argument("--type-filter", default="all", help="all, text, image")
    
    del_parser = subparsers.add_parser("delete")
    del_parser.add_argument("id", type=int)
    
    subparsers.add_parser("clear")
    
    pin_parser = subparsers.add_parser("pin")
    pin_parser.add_argument("id", type=int)
    
    unpin_parser = subparsers.add_parser("unpin")
    unpin_parser.add_argument("id", type=int)

    edit_parser = subparsers.add_parser("edit")
    edit_parser.add_argument("id", type=int)
    edit_parser.add_argument("content")
    
    get_parser = subparsers.add_parser("get")
    get_parser.add_argument("id", type=int)
    
    cfg_parser = subparsers.add_parser("config")
    
    open_parser = subparsers.add_parser("open-url")
    open_parser.add_argument("url")
    
    img_parser = subparsers.add_parser("open-image")
    img_parser.add_argument("filepath")
    
    cfg_sub = cfg_parser.add_subparsers(dest="cfg_cmd")
    
    c_set = cfg_sub.add_parser("set")
    c_set.add_argument("key")
    c_set.add_argument("value")
    
    c_get = cfg_sub.add_parser("get")
    c_get.add_argument("key")
    
    c_setjson = cfg_sub.add_parser("set-json")
    c_setjson.add_argument("key")
    c_setjson.add_argument("value")
    
    c_getjson = cfg_sub.add_parser("get-json")
    c_getjson.add_argument("key")
    
    theme_parser = subparsers.add_parser("theme")
    theme_sub = theme_parser.add_subparsers(dest="theme_cmd")
    theme_sub.add_parser("get")
    theme_sub.add_parser("list")
    theme_sub.add_parser("generate-example")
    
    args = parser.parse_args()
    
    init_db()
    
    if args.command == "watch":
        if get_setting("auto_delete", "false") == "true":
            log("Auto-delete enabled, clearing non-pinned history on startup...")
            clear()
        watch()
    elif args.command == "store":
        store()
    elif args.command == "list":
        db_list(args.search, args.type_filter)
    elif args.command == "delete":
        delete(args.id)
    elif args.command == "clear":
        clear()
    elif args.command == "pin":
        set_pin(args.id, True)
    elif args.command == "unpin":
        set_pin(args.id, False)
    elif args.command == "edit":
        edit_item(args.id, args.content)
    elif args.command == "get":
        get_clip(args.id)
    elif args.command == "config":
        if args.cfg_cmd == "set":
            set_setting(args.key, args.value)
        elif args.cfg_cmd == "get":
            print(get_setting(args.key, ""))
        elif args.cfg_cmd == "set-json":
            set_json_setting(args.key, args.value)
        elif args.cfg_cmd == "get-json":
            print(get_json_setting(args.key, "xdg-open" if args.key == "image_viewer" else ""))
    elif args.command == "open-url":
        open_url(args.url)
    elif args.command == "open-image":
        open_image(args.filepath)
    elif args.command == "theme":
        THEMES = {
            "Dark": {
                "bgColor": "#121212",
                "fgColor": "#e8eaed",
                "cardColor": "#1e1e1e",
                "cardHover": "#2c2c2c",
                "accentColor": "#8ab4f8",
                "dangerColor": "#f28b82",
                "shadowColor": "#000000"
            },
            "Light": {
                "bgColor": "#f0f0f0",
                "fgColor": "#000000",
                "cardColor": "#ffffff",
                "cardHover": "#e0e0e0",
                "accentColor": "#0067c0",
                "dangerColor": "#d32f2f",
                "shadowColor": "#cccccc"
            },
            "Catppuccin Macchiato": {
                "bgColor": "#24273a",
                "fgColor": "#cad3f5",
                "cardColor": "#363a4f",
                "cardHover": "#494d64",
                "accentColor": "#8aadf4",
                "dangerColor": "#ed8796",
                "shadowColor": "#181926"
            },
            "Nord": {
                "bgColor": "#2e3440",
                "fgColor": "#eceff4",
                "cardColor": "#3b4252",
                "cardHover": "#434c5e",
                "accentColor": "#88c0d0",
                "dangerColor": "#bf616a",
                "shadowColor": "#2e3440"
            },
            "Dracula": {
                "bgColor": "#282a36",
                "fgColor": "#f8f8f2",
                "cardColor": "#44475a",
                "cardHover": "#6272a4",
                "accentColor": "#bd93f9",
                "dangerColor": "#ff5555",
                "shadowColor": "#282a36"
            },
            "Gruvbox": {
                "bgColor": "#282828",
                "fgColor": "#ebdbb2",
                "cardColor": "#3c3836",
                "cardHover": "#504945",
                "accentColor": "#83a598",
                "dangerColor": "#cc241d",
                "shadowColor": "#1d2021"
            }
        }      
        custom_path = os.path.expanduser("~/.config/jcm/themes.json")
        if os.path.exists(custom_path):
            try:
                with open(custom_path, 'r') as f:
                    custom_themes = json.load(f)
                    for k, v in custom_themes.items():
                        if isinstance(v, dict):
                            THEMES[k] = v
            except Exception as e:
                log(f"Failed to load custom themes: {e}")
        
        if args.theme_cmd == "list":
            print(json.dumps(list(THEMES.keys())))
        elif args.theme_cmd == "get":
            theme_name = get_setting("theme", "Dark")
            theme_data = THEMES.get(theme_name, THEMES["Dark"])
            print(json.dumps(theme_data))
        elif args.theme_cmd == "generate-example":
            example = {
                "Example Custom Theme": {
                    "bgColor": "#000000",
                    "fgColor": "#00ff00",
                    "cardColor": "#111111",
                    "cardHover": "#222222",
                    "accentColor": "#00aa00",
                    "dangerColor": "#ff0000",
                    "shadowColor": "#0a0a0a"
                }
            }
            if not os.path.exists(os.path.dirname(custom_path)):
                os.makedirs(os.path.dirname(custom_path), exist_ok=True)
            try:
                with open(custom_path, 'w') as f:
                    json.dump(example, f, indent=4)
                print(f"Example themes saved to {custom_path}")
            except Exception as e:
                print(f"Failed to generate example themes: {e}")
            
if __name__ == "__main__":
    main()
